# ── Database (Supabase) ────────────────────────────────────────────────────────
# Get both from: Supabase Dashboard → Project Settings → Database → Connection string
# Use "Transaction" mode URL for DATABASE_URL (port 6543)
# Use "Direct" connection URL for DIRECT_URL (port 5432)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# ── NextAuth ───────────────────────────────────────────────────────────────────
# Generate a secret: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="your_nextauth_secret_min_32_chars"
# On Vercel: set this to your actual deployment URL after first deploy
NEXTAUTH_URL="https://your-app.vercel.app"

# ── Google OAuth (optional — enables "Sign in with Google") ───────────────────
# Get from: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# ── Razorpay Payments ──────────────────────────────────────────────────────────
# Get from: dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_..."
# Get from: Razorpay Dashboard → Webhooks → Secret
RAZORPAY_WEBHOOK_SECRET="your_razorpay_webhook_secret"

# ── Gemini AI Chatbot ──────────────────────────────────────────────────────────
# Get from: aistudio.google.com → Get API Key
# Format: AIzaSy... (starts with AIza)
GEMINI_API_KEY="AIzaSy..."

# ── Cloudinary (image uploads) ─────────────────────────────────────────────────
# Get from: cloudinary.com → Dashboard → Account Details → API Environment variable
CLOUDINARY_URL="cloudinary://API_KEY:API_SECRET@CLOUD_NAME"

# ── Resend (transactional email) ───────────────────────────────────────────────
# Get from: resend.com → API Keys → Create API Key
RESEND_API_KEY="re_..."

# ── OpenWeatherMap (destination weather widget) ────────────────────────────────
# Get from: openweathermap.org → My API Keys (free tier is enough)
# If missing: shows mock weather data (28°C, clear sky)
OPENWEATHER_API_KEY="your_openweather_api_key"

# ── Google Maps (destination map embeds) ───────────────────────────────────────
# Get from: console.cloud.google.com → Maps Embed API
# If missing: uses OpenStreetMap (free, no key needed)
GOOGLE_MAPS_API_KEY="your_google_maps_api_key"
